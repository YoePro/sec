module units_advanced_invalid

// This file specifies diagnostics for the intended complete unit-definition
// model. Every marked declaration or expression is intentionally invalid.

// =============================================================================
// Valid units used by invalid cases
// =============================================================================

unit m decimal physical
impl m {
    dimension: [length^1]
    scale: 1
    system: SI
}

unit s decimal physical
impl s {
    dimension: [time^1]
    scale: 1
    system: SI
}

unit kg decimal physical
impl kg {
    dimension: [mass^1]
    scale: 1
    system: SI
}

unit Hz decimal physical
impl Hz {
    dimension: [time^-1]
    scale: 1
    system: SI
}

unit rpm physical
impl rpm {
    dimension: [time^-1]
    scale: 1 / 60
    system: Other

    fn rpm(value: Hz) rpm {
        return value * 60
    }
}

unit Bq decimal physical
impl Bq {
    dimension: [time^-1]
    scale: 1
    system: SI
}

unit mps decimal physical
impl mps {
    dimension: [length^1, time^-1]
    scale: 1
    system: SI
}

unit kph decimal physical
impl kph {
    dimension: [length^1, time^-1]
    scale: 5 / 18
    system: SI
}

unit N decimal physical
impl N {
    dimension: [mass^1, length^1, time^-2]
    scale: 1
    system: SI
}

unit SEK decimal other
impl SEK {
    dimension: [currency.SEK^1]
    scale: 1
    system: Currency
}

unit EUR decimal other
impl EUR {
    dimension: [currency.EUR^1]
    scale: 1
    system: Currency
}

// =============================================================================
// Missing and duplicate metadata
// =============================================================================

unit MissingDimension decimal physical
impl MissingDimension {
    // ERROR: A physical unit must declare a dimension vector.
    scale: 1
    system: SI
}

unit MissingScale decimal physical
impl MissingScale {
    dimension: [length^1]
    // ERROR: A physical unit must declare a scale.
    system: SI
}

unit MissingSystem decimal physical
impl MissingSystem {
    dimension: [length^1]
    scale: 1
    // ERROR: A physical unit must declare a system.
}

unit DuplicateDimension decimal physical
impl DuplicateDimension {
    dimension: [length^1]
    // ERROR: dimension may be declared only once.
    dimension: [length^1]
    scale: 1
    system: SI
}

unit DuplicateScale decimal physical
impl DuplicateScale {
    dimension: [length^1]
    scale: 1
    // ERROR: scale may be declared only once.
    scale: 1000
    system: SI
}

unit DuplicateSystem decimal physical
impl DuplicateSystem {
    dimension: [length^1]
    scale: 1
    system: SI
    // ERROR: system may be declared only once.
    system: Imperial
}

// =============================================================================
// Invalid dimension vectors
// =============================================================================

unit ZeroExponent decimal physical
impl ZeroExponent {
    // ERROR: Dimension exponents must be non-zero.
    dimension: [length^0]
    scale: 1
    system: SI
}

unit FractionalExponent decimal physical
impl FractionalExponent {
    // ERROR: Dimension exponents must be integers.
    dimension: [length^1.5]
    scale: 1
    system: SI
}

unit MissingExponent decimal physical
impl MissingExponent {
    // ERROR: Every dimension entry requires an explicit exponent.
    dimension: [length]
    scale: 1
    system: SI
}

unit DuplicateAxis decimal physical
impl DuplicateAxis {
    // ERROR: A dimension axis may occur only once in a declaration.
    dimension: [length^1, time^-1, length^1]
    scale: 1
    system: SI
}

unit EmptyPhysicalDimension decimal physical
impl EmptyPhysicalDimension {
    // ERROR: An ordinary physical unit may not have an empty dimension vector.
    dimension: []
    scale: 1
    system: SI
}

// =============================================================================
// Invalid scales
// =============================================================================

unit ZeroScale decimal physical
impl ZeroScale {
    dimension: [length^1]
    // ERROR: Scale must be non-zero.
    scale: 0
    system: SI
}

unit NegativeScale decimal physical
impl NegativeScale {
    dimension: [length^1]
    // ERROR: Scale must be positive unless a future affine model permits it.
    scale: -1
    system: SI
}

unit DivisionByZeroScale decimal physical
impl DivisionByZeroScale {
    dimension: [length^1]
    // ERROR: Scale constant evaluation must reject division by zero.
    scale: 1 / 0
    system: SI
}

fn RuntimeScale() decimal {
    return 1000
}

unit NonConstantScale decimal physical
impl NonConstantScale {
    dimension: [length^1]
    // ERROR: Scale must be a compile-time numeric expression.
    scale: RuntimeScale()
    system: SI
}

// =============================================================================
// Metadata is valid only for units
// =============================================================================

type NotAUnit decimal
impl NotAUnit {
    // ERROR: dimension metadata is valid only in a unit impl.
    dimension: [length^1]
    // ERROR: scale metadata is valid only in a unit impl.
    scale: 1
    // ERROR: system metadata is valid only in a unit impl.
    system: SI
}

// =============================================================================
// Implicit conversion remains forbidden
// =============================================================================

fn ImplicitFrequencyConversion(value: Hz) void {
    // ERROR: Equal dimensions do not permit implicit conversion to rpm.
    let rotation: rpm := value
}

fn ImplicitSemanticConversion(value: Hz) void {
    // ERROR: Hz and Bq remain distinct nominal units.
    let activity: Bq := value
}

fn ImplicitScaleConversion(value: kph) void {
    // ERROR: kph and mps have different scales and require explicit conversion.
    let speed: mps := value
}

fn ImplicitCurrencyConversion(value: SEK) void {
    // ERROR: Currency dimensions are incompatible without an explicit runtime
    // conversion relationship.
    let converted: EUR := value
}

// =============================================================================
// Scale-sensitive algebra
// =============================================================================

fn KilometresPerHourAssignedToMps(distance: km, duration: h) mps {
    // ERROR: km/h has the kph scale, not the mps scale.
    return distance / duration
}

// Local declarations provide the scaled units for the preceding case.
unit km decimal physical
impl km {
    dimension: [length^1]
    scale: 1000
    system: SI
}

unit h decimal physical
impl h {
    dimension: [time^1]
    scale: 3600
    system: Other
}

fn MetresPerSecondAssignedToKph(distance: m, duration: s) kph {
    // ERROR: m/s has the mps scale, not the kph scale.
    return distance / duration
}

// =============================================================================
// Invalid explicit conversion functions
// =============================================================================

unit BadDistanceConversion decimal physical
impl BadDistanceConversion {
    dimension: [length^1]
    scale: 1
    system: SI

    // ERROR: Time and length dimensions are incompatible.
    fn BadDistanceConversion(value: s) BadDistanceConversion {
        return value
    }
}

unit WrongConversionReturn decimal physical
impl WrongConversionReturn {
    dimension: [length^1]
    scale: 1
    system: SI

    // ERROR: A unit conversion function must return its containing unit.
    fn WrongConversionReturn(value: m) m {
        return value
    }
}

unit WrongConversionName decimal physical
impl WrongConversionName {
    dimension: [length^1]
    scale: 1
    system: SI

    // ERROR: Constructor-style conversion requires the target unit name.
    fn Convert(value: m) WrongConversionName {
        return value
    }
}

unit ReceiverConversion decimal physical
impl ReceiverConversion {
    dimension: [length^1]
    scale: 1
    system: SI

    // ERROR: Unit conversion functions are static and cannot declare self.
    fn ReceiverConversion(ref self, value: m) ReceiverConversion {
        return value
    }
}

unit DuplicateSourceConversion decimal physical
impl DuplicateSourceConversion {
    dimension: [length^1]
    scale: 1
    system: SI

    fn DuplicateSourceConversion(value: m) DuplicateSourceConversion {
        return value
    }

    // ERROR: Duplicate conversion from source unit m.
    fn DuplicateSourceConversion(other: m) DuplicateSourceConversion {
        return other
    }
}

unit NumericSourceConversion decimal physical
impl NumericSourceConversion {
    dimension: [length^1]
    scale: 1
    system: SI

    // ERROR: The source of a direct unit conversion must be another unit type.
    fn NumericSourceConversion(value: decimal) NumericSourceConversion {
        return value
    }
}

// =============================================================================
// Invalid conversion calls
// =============================================================================

fn WrongConversionArgument(value: m) void {
    // ERROR: rpm has a conversion from Hz, not from m.
    let rotation: rpm := rpm(value)
}

fn ConversionDoesNotHappenByAssignment(value: Hz) void {
    let mut rotation: rpm := rpm(value)

    // ERROR: Later assignment still requires an explicit conversion call.
    rotation = value
}

// =============================================================================
// Invalid complex algebra
// =============================================================================

fn ForceAssignedToSpeed(mass: kg, speed: mps, duration: s) mps {
    // ERROR: kg*m/s/s is force, not speed.
    return mass * speed / duration
}

fn PressureWithoutArea(force: N, distance: m) void {
    // ERROR: N/m is not a pressure dimension.
    let pressure: Pa := force / distance
}

unit Pa decimal physical
impl Pa {
    dimension: [mass^1, length^-1, time^-2]
    scale: 1
    system: SI
}

fn CurrencySquared(first: SEK, second: SEK) void {
    // ERROR: Squared currency remains unsupported.
    let invalid := first * second
}
