{
  "name": "sec-syntax",
  "displayName": "SEC Language",
  "description": "SEC is a compiled, high-performance language with strong static typing, semantic typing, units-of-measure, generics, explicit unsafe code, and support for comments and string interpolation.",
  "version": "0.1.0",
  "publisher": "sec-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoePro/sec-syntax"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sec"
  ],
  "categories": ["Programming Languages"],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "sec",
        "aliases": ["SEC", "SEC Language", "sec"],
        "extensions": [".sec", ".se"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sec",
        "scopeName": "source.sec",
        "path": "./syntaxes/sec.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[sec]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "sec-lang.sec-syntax"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "support.type.unit.sec",
            "settings": {
              "foreground": "#4F7A5A"
            }
          },
          {
            "scope": "keyword.other.unit-metadata.sec",
            "settings": {
              "foreground": "#9A6A2F",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "constant.language.unit-status.sec",
            "settings": {
              "foreground": "#B44A3A",
              "fontStyle": "italic"
            }
          },
          {
            "scope": "keyword.other.implements.sec",
            "settings": {
              "fontStyle": "italic"
            }
          }
        ]
      }
    },
    "configuration": {
      "title": "SEC",
      "properties": {
        "sec.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the SEC language server. Leave empty to use `bin/lsp-sec` or `bin/lsp-sec.exe` inside the extension. Windows example: `C:\\\\Users\\\\Accountname\\\\.vscode\\\\extensions\\\\sec-lang.sec-syntax\\\\bin\\\\lsp-sec.exe`."
        }
      }
    }
  }
}
