module register

unit rpm uint physical

// 1. Basic 8-bit register with exact matching bit width (4 + 1 + 3 = 8)
type Protocol register[8] {
    Speed: bit[4]<rpm>,
    Enabled: bit,
    _: bit[3],
}

// 2. 16-bit register testing implicit bit[1] width and multiple reserved fields (1 + 3 + 4 + 8 = 16)
type Control register[16] {
    Enabled: bit,
    _: bit[3],
    Mode: bit[4],
    _: bit[8],
}

// 3. Large register layout to verify higher bit numbers (32-bit hardware layout)
type SystemConfig register[32] {
    Status: bit[8],
    _: bit[8],
    InterruptMask: bit[12],
    Enabled: bit,
    _: bit[3],
}

// 4. Memory-mapped register instance bound to a linear hardware address
@address(0x40021000)
let motorStatus: Protocol

@address(0x40022000)
let systemReg: SystemConfig

// 5. Valid assignments inside functions with compatible types and units
fn TestValidAssignments() void {
    // Reading from a bit field with a matching unit type
    let currentSpeed: rpm := motorStatus.Speed

    // Reading a clean bit field into an un-typed variable (type inference)
    let isEnabled := motorStatus.Enabled
}

// 4. Funktion som visar giltig tilldelning och enhetsmatchning
fn TestValidUsage() void {
    let speed: rpm := motorStatus.Speed
}
