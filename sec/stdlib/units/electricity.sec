/** Volt-Ampere (Apparent Power) */
unit VA decimal physical
impl VA {
    dimension: [mass^1, length^2, time^-3]
    scale: 1
    system: SI

    fn VA(Volt: decimal<V>, Amp: decimal<A>) decimal<VA> {
        return decimal<VA>(decimal(Volt) * decimal(Amp))
    }

    fn VA(Volt: float<V>, Amp: float<A>) float<VA> {
        return float<VA>(float(Volt) * float(Amp))
    }
}

/** Volt-Ampere Reactive (Reactive Power) */
unit var decimal physical
impl var {
    dimension: [mass^1, length^2, time^-3]
    scale: 1
    system: SI

    // Created from Volt and Ampere under reactive conditions
    fn var(Volt: decimal<V>, Amp: decimal<A>) decimal<var> {
        return decimal<var>(decimal(Volt) * decimal(Amp))
    }

    fn var(Volt: float<V>, Amp: float<A>) float<var> {
        return float<var>(float(Volt) * float(Amp))
    }
}

/** Ampere-hour (Battery Charge Capacity) */
unit Ah decimal physical
impl Ah {
    dimension: [electric_current^1, time^1]
    scale: 3600 // 1 hour = 3600 seconds
    system: SI

    /** Convert Coulomb to Ampere-hours (1 Ah = 3600 C) */
    fn Ah(Coulomb: decimal<C>) decimal<Ah> {
        return decimal<Ah>(decimal(Coulomb) / 3600d)
    }

    fn Ah(Coulomb: float<C>) float<Ah> {
        return float<Ah>(float(Coulomb) / 3600f)
    }
}
