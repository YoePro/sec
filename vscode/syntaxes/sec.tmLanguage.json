{
  "scopeName": "source.sec",
  "name": "Sec",
  "fileTypes": ["sec"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#directives" },
    { "include": "#enums" },
    { "include": "#declarations" },
    { "include": "#units" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sec",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.sec",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sec",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.sec",
          "begin": "\\$\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sec",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.sec",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "name": "entity.name.function.attribute.sec",
          "match": "@[A-Za-z_][A-Za-z0-9_.]*"
        }
      ]
    },

    "directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.sec",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "enums": {
      "patterns": [
        {
          "name": "meta.enum.declaration.sec",
          "begin": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+([A-Za-z_][A-Za-z0-9_]*))?\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "storage.type.enum.sec"
            },
            "2": {
              "name": "entity.name.type.enum.sec"
            },
            "3": {
              "name": "storage.type.primitive.sec"
            },
            "4": {
              "name": "punctuation.section.block.begin.sec"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.sec"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "constant.other.enum-member.sec",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?:,|=|\\}))"
            },
            {
              "name": "punctuation.separator.comma.sec",
              "match": ","
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#operators"
            }
          ]
        },
        {
          "name": "meta.enum.declaration.sec",
          "begin": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_.]*)\\s+(enum)\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "storage.type.declaration.sec"
            },
            "2": {
              "name": "entity.name.type.enum.sec"
            },
            "3": {
              "name": "storage.type.enum.sec"
            },
            "4": {
              "name": "punctuation.section.block.begin.sec"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.sec"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "constant.other.enum-member.sec",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?:,|=|\\}))"
            },
            {
              "name": "punctuation.separator.comma.sec",
              "match": ","
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#operators"
            }
          ]
        },
        {
          "name": "meta.enum.member.access.sec",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.enum.sec"
            },
            "2": {
              "name": "punctuation.accessor.sec"
            },
            "3": {
              "name": "constant.other.enum-member.sec"
            }
          }
        }
      ]
    },
    "units": {
      "patterns": [
        {
          "name": "meta.unit.annotation.sec",
          "begin": "<",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.unit.begin.sec" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.unit.end.sec" }
          },
          "patterns": [
            {
              "name": "support.type.unit.sec",
              "match": "[A-Za-z_][A-Za-z0-9_.]*"
            },
            {
              "name": "keyword.operator.unit.sec",
              "match": "[*/^\\-]"
            },
            {
              "name": "constant.numeric.unit-exponent.sec",
              "match": "\\d+"
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sec",
          "match": "(?<![A-Za-z0-9_])(?:\\d+\\.\\d*|\\.\\d+)(?:[fFdD])?\\b"
        },
        {
          "name": "constant.numeric.integer.sec",
          "match": "\\b(?:0[bB][01_]+|0[oO][0-7_]+|0[xX][0-9A-Fa-f_]+|\\d[\\d_]*)(?:[iIuUfFdD])?\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sec",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.option.sec",
          "match": "\\b(?:Some|None|Ok|Err)\\b"
        },
        {
          "name": "constant.language.unit-status.sec",
          "match": "\\b(?:active|deprecated|obsolete)\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "name": "meta.module.sec",
          "match": "\\b(module)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.other.module.sec" },
            "2": { "name": "entity.name.namespace.sec" }
          }
        },
        {
          "name": "meta.import.sec",
          "match": "\\b(import)\\b",
          "captures": {
            "1": { "name": "keyword.other.import.sec" }
          }
        },
        {
          "name": "meta.target.directive.sec",
          "match": "(#)(target)\\s*\\(([^)]*)\\)",
          "captures": {
            "1": { "name": "punctuation.definition.directive.sec" },
            "2": { "name": "keyword.other.directive.sec" },
            "3": { "name": "meta.directive.arguments.sec" }
          }
        },
        {
          "name": "meta.unit.definition.sec",
          "match": "\\b(unit)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+(?!(?:physical|currency|other)\\b)([A-Za-z_][A-Za-z0-9_.]*(?:<[^>]+>)?(?:\\[[^\\]]+\\])?))?(?:\\s+(physical|currency|other))?",
          "captures": {
            "1": { "name": "storage.type.unit.declaration.sec" },
            "2": { "name": "entity.name.type.unit.sec" },
            "3": { "name": "storage.type.sec" },
            "4": { "name": "keyword.other.unit-category.sec" }
          }
        },
        {
          "name": "meta.type.definition.sec",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+(struct|interface|enum|union|register))?(?:\\s+(implements))?(?:\\s*(=))?",
          "captures": {
            "1": { "name": "storage.type.declaration.sec" },
            "2": { "name": "entity.name.type.sec" },
            "3": { "name": "storage.type.sec" },
            "4": { "name": "keyword.other.implements.sec" },
            "5": { "name": "keyword.operator.assignment.sec" }
          }
        },
        {
          "name": "meta.interface.definition.sec",
          "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+(implements))?",
          "captures": {
            "1": { "name": "storage.type.interface.sec" },
            "2": { "name": "entity.name.type.interface.sec" },
            "3": { "name": "keyword.other.implements.sec" }
          }
        },
        {
          "name": "meta.function.definition.sec",
          "match": "\\b(?:(unsafe)\\s+)?(?:(extern)\\s+)?(fn)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.control.unsafe.sec" },
            "2": { "name": "storage.modifier.extern.sec" },
            "3": { "name": "storage.type.function.sec" },
            "4": { "name": "entity.name.function.sec" }
          }
        },
        {
          "name": "meta.property.definition.sec",
          "match": "\\b(property)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*(<[^>]+>|[A-Za-z_][A-Za-z0-9_.]*(?:<[^>]+>)?(?:\\[[^\\]]+\\])?)",
          "captures": {
            "1": { "name": "storage.type.property.sec" },
            "2": { "name": "entity.name.property.sec" },
            "3": { "name": "punctuation.separator.type.sec" },
            "4": { "name": "storage.type.sec" }
          }
        },
        {
          "name": "meta.unit.metadata.sec",
          "match": "\\b([Dd]imension|[Ss]cale|[Ss]ystem|[Ll]ong_?[Nn]ame|[Ss]ymbol|[Bb]ase_?[Uu]nit|[Ss]tatus)\\s*(:)",
          "captures": {
            "1": { "name": "keyword.other.unit-metadata.sec" },
            "2": { "name": "punctuation.separator.key-value.sec" }
          }
        },
        {
          "name": "meta.impl.sec",
          "match": "\\b(impl)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "storage.type.implementation.sec" },
            "2": { "name": "entity.name.type.sec" }
          }
        },
        {
          "name": "meta.struct.field.sec",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*(<[^>]+>|[A-Za-z_][A-Za-z0-9_.]*(?:<[^>]+>)?(?:\\[[^\\]]+\\])?)",
          "captures": {
            "1": { "name": "variable.other.member.sec" },
            "2": { "name": "punctuation.separator.type.sec" },
            "3": { "name": "storage.type.sec" }
          }
        },
        {
          "name": "meta.variable.declaration.sec",
          "match": "\\b(let)\\s+(?:(mut)\\s+)?([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(:)\\s*(<[^>]+>|[A-Za-z_][A-Za-z0-9_.]*(?:<[^>]+>)?(?:\\[[^\\]]+\\])?))?",
          "captures": {
            "1": {
              "name": "storage.type.variable.sec"
            },
            "2": {
              "name": "storage.modifier.mutable.sec"
            },
            "3": {
              "name": "variable.other.declaration.sec"
            },
            "4": {
              "name": "punctuation.separator.type.sec"
            },
            "5": {
              "name": "entity.name.type.sec"
            }
          }
        },
        {
          "name": "meta.typed.variable.declaration.sec",
          "match": "\\b(<[^>]+>|[A-Za-z_][A-Za-z0-9_.]*(?:<[^>]+>)?(?:\\[[^\\]]+\\])?)\\s+(mut)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.type.sec" },
            "2": { "name": "storage.modifier.mutable.sec" },
            "3": { "name": "punctuation.separator.type.sec" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sec",
          "match": "\\b(?:asm|if|else|switch|case|default|fallthrough|for|while|in|match|where|return|break|continue|defer|try|await|spawn|discard|assert|panic|unsafe)\\b"
        },
        {
          "name": "storage.type.declaration.sec",
          "match": "\\b(?:type|enum|struct|register|interface|impl|fn|unit|property)\\b"
        },
        {
          "name": "storage.modifier.mutable.sec",
          "match": "\\bmut\\b"
        },
        {
          "name": "storage.modifier.reference.sec",
          "match": "\\bref\\b"
        },
        {
          "name": "storage.modifier.extern.sec",
          "match": "\\bextern\\b"
        },
        {
          "name": "variable.language.self.sec",
          "match": "\\bself\\b"
        },
        {
          "name": "keyword.other.implements.sec",
          "match": "\\bimplements\\b"
        },
        {
          "name": "keyword.other.unit-metadata.sec",
          "match": "\\b(?:[Dd]imension|[Ss]cale|[Ss]ystem|[Ll]ong_?[Nn]ame|[Ss]ymbol|[Bb]ase_?[Uu]nit|[Ss]tatus)\\b"
        },
        {
          "name": "keyword.other.unit-category.sec",
          "match": "\\b(?:physical|currency|other)\\b"
        },
        {
          "name": "keyword.other.property-accessor.sec",
          "match": "\\b(?:get|set)\\b"
        },
        {
          "name": "keyword.other.sec",
          "match": "\\b(?:module|import|require|range|validate|regex|minLen|maxLen|minLength|maxLength|precision|iota|capture|arena|sec)\\b"
        }
      ]
    },    

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.sec",
          "match": "\\b(?:bool|byte|char|rune|int|int8|int16|int32|int64|int128|int256|uint|uint8|uint16|uint32|uint64|uint128|uint256|float|float32|float64|decimal|decimal128|string|void|ptr)\\b"
        },
        {
          "name": "support.type.sec",
          "match": "\\b(?:Result|Option|Vec|Map|Set|Vector|Matrix|Box|Any|RawPtr)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.setter.parameter.sec",
          "match": "\\b(set)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.other.setter.sec"
            },
            "2": {
              "name": "variable.parameter.sec"
            }
          }
        },
        {
          "name": "meta.setter.parameter.sec",
          "match": "\\b(try)\\s+(set)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.try.sec"
            },
            "2": {
              "name": "keyword.other.setter.sec"
            },
            "3": {
              "name": "variable.parameter.sec"
            }
          }
        },
        {
          "name": "variable.other.member.sec",
          "match": "(?<=\\.)[a-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.private.sec",
          "match": "\\b__?[a-zA-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },    
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sec",
          "match": "\\.\\.\\.|\\.\\.<|\\.\\.|==|!=|<=|>=|&&|\\|\\||<<=|>>=|<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|:=|=>|[+\\-*/%=&|^~!<>]"
        }
      ]
    }
  }
}
