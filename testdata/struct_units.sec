module main

type Meter decimal<m>
type Second decimal<s>
type Speed decimal<m/s>

type Vehicle struct {
    _speed: Speed `json:"speed"`,
}

impl Vehicle {
    property TopSpeed: Speed {
        get {
            return _speed
        }

        try set value {
            _speed = value
        }
    }
}

let speed: Speed := 50 
let vehicle := Vehicle{ _speed: speed }

let current := vehicle._speed
let top := vehicle.TopSpeed 

//vehicle.TopSpeed = speed // should fail: fallible property assignment requires try
type Money decimal<SEK>
