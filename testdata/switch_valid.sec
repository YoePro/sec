module main

fn BasicValueSwitch(value: int) int {
    switch value {
    case 1:
        return 10
    case 2:
        return 20

    default:
        return 30
    }
}

fn MultipleValues(value: int) int {
    switch value {
    case 1, 3, 5, 7:
        return 1
    case 2, 4, 6, 8:
        return 2
    default:
        return 0
    }
}

fn IntegerRanges(score: int) int {
    switch score {
        case 0..<50:
            return 0

        case 50..<80:
            return 1

        case 80..100:
            return 2

        default:
            return -1
    }
}

fn OpenRanges(value: int) int {
    switch value {
        case ..<0:
            return -1
        case 0..100:
            return 0

        case 101..:
            return 1

        default:
            return 2
    }
}

fn RelationalCases(value: int) int {
    switch value {
        case < 0:
            return -1
        case 0:
            return 0
        case > 0:
            return 1

        default:
            return 2
    }
}

fn RelationalBoundaries(value: int) int {
    switch value {
    case <= -10:
        return -2
    case < 0:
        return -1
    case 0:
        return 0

    case < 10:
        return 1

    case >= 10:
        return 2

    default:
        return 3
    }
}

fn MixedCaseItems(value: int) int {
    switch value {
    case < 0, > 100:
        return -1
    case 0, 10, 20..<30:
        return 1
    default:
        return 0
    }
}

fn VariableCaseValues(value: int, first: int, second: int) int {
    switch value {
    case first:
        return 1
    case second:
        return 2

    default:
        return 0
    }
}

fn VariableRangeBounds(value: int, minimum: int, maximum: int) int {
    switch value {
    case minimum..<maximum:
        return 1
    default:
        return 0
    }
}

fn ExpressionCaseValues(value: int, base: int) int {
    switch value {
    case base + 1:
        return 1
    case base * 2:
        return 2

    default:
        return 0
    }
}

fn StringSwitch(value: string) int {
    switch value {
    case "start":
        return 1
    case "stop":
        return 2

    case "pause", "wait":
        return 3

    default:
        return 0
    }
}

fn BoolSwitch(value: bool) int {
    switch value {
    case true:
        return 1
    case false:
        return 0
    }
}

fn BoolSwitchWithDefault(value: bool) int {
    switch value {
    case true:
        return 1
    default:
        return 0
    }
}

fn SubjectlessBasic(value: int) int {
    switch {
    case value < 0:
        return -1

    case value == 0:
        return 0

    case value > 0:
        return 1

    default:
        return 2
    }
}

fn SubjectlessLogical(    ready: bool,    forced: bool,    cancelled: bool) int {
    switch {
    case cancelled:
        return -1
    case ready || forced:
        return 1

    default:
        return 0
    }
}

fn SubjectlessMultipleConditions(first: bool,second: bool,third: bool) int {
    switch {
    case first, second:
        return 1
    case third:
        return 2

    default:
        return 0
    }
}

fn SubjectlessRange(value: int) int {
    switch {
    case value in 0..<10:
        return 1

    case value in 10..20:
        return 2

    default:
        return 0
    }
}

fn NoDefault(value: int) int {
    let mut result: int := 0

    switch value {
    case 1:
        result = 10

    case 2:
        result = 20
    }

    return result
}

fn EmptySwitch(value: int) void {
    switch value {
    }
}

fn EmptyCase(value: int) int {
    let mut result: int := 0

    switch value {
    case 1:

    case 2:
        result = 20

    default:
        result = 30
    }

    return result
}

fn ExplicitFallthrough(value: int) int {
    let mut result: int := 0

    switch value {
    case 1:
        result = 10
        fallthrough

    case 2:
        result += 20

    default:
        result += 30
    }

    return result
}

fn FallthroughIntoReturningCase(value: int) int {
    switch value {
    case 1:
        fallthrough

    case 2:
        return 20

    default:
        return 30
    }
}

fn MultipleFallthrough(value: int) int {
    switch value {
    case 1:
        fallthrough
    case 2:
        fallthrough
    case 3:
        return 10

    default:
        return 20
    }
}

fn CaseScopes(value: int) int {
    let mut result: int := 0

    switch value {
    case 1:
        let local: int := 10
        result = local

    case 2:
        let local: int := 20
        result = local

    default:
        let local: int := 30
        result = local
    }

    return result
}

fn MutateOuter(value: int) int {
    let mut result: int := 0

    switch value {
    case 1:
        result = 10

    case 2:
        result = 20

    default:
        result = 30
    }

    return result
}

fn DefiniteAssignment(value: int) int {
    let mut result: int

    switch value {
    case 1:
        result = 10

    case 2:
        result = 20

    default:
        result = 30
    }

    return result
}

fn DefiniteAssignmentWithReturn(value: int) int {
    let mut result: int

    switch value {
    case 1:
        result = 10

    case 2:
        return 20

    default:
        result = 30
    }

    return result
}

fn AllCasesReturn(value: int) int {
    switch value {
    case < 0:
        return -1

    case 0:
        return 0

    default:
        return 1
    }
}

fn AllBoolCasesReturn(value: bool) int {
    switch value {
    case true:
        return 1
    case false:
        return 0
    }
}

fn SubjectlessAllCasesReturn(value: int) int {
    switch {
    case value < 0:
        return -1
    case value == 0:
        return 0

    default:
        return 1
    }
}

fn NestedSwitch(first: int, second: int) int {
    switch first {
    case 1:
        switch second {
        case 1:
            return 11

        case 2:
            return 12

        default:
            return 10
        }

    case 2:
        return 20

    default:
        return 0
    }
}

fn SwitchInsideFor(target: int) int {
    let mut result: int := 0

    for value in 0..<10 {
        switch value {
        case 0:
            continue

        case 5:
            result = target

        default:
            result += 1
        }
    }

    return result
}

fn SwitchInsideWhile(limit: int) int {
    let mut value: int := 0
    while value < limit {
        switch value {
        case 5:
            return value
        default:
            value += 1
        }
    }

    return value
}

fn NumericLiteralCases(value: int) int {
    switch value {
    case 0b0001:
        return 1
    case 0o10:
        return 8

    case 0x10:
        return 16

    default:
        return 0
    }
}

fn TypedIntegerSubject(value: uint) int {
    switch value {
    case 0u:
        return 0
    case 1u:
        return 1

    default:
        return 2
    }
}

fn SubjectExpression(value: int) int {
    switch value + 1 {
    case 1:
        return 1

    case 2:
        return 2

    default:
        return 0
    }
}
