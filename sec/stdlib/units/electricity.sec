module units

// =============================================================================
// Electrical SI-derived units
// =============================================================================

/** Coulomb */
unit C decimal physical
impl C {
    dimension: [electric_current^1, time^1]
    scale: 1
    system: SI

    // --- Base formula: Q = I * t (Ampere * Second) ---

    fn C(Amp: decimal<A>, Second: decimal<s>) decimal<C> {
        return decimal<C>(decimal(Amp) * decimal(Second))
    }

    fn C(Amp: float<A>, Second: float<s>) float<C> {
        return float<C>(float(Amp) * float(Second))
    }

    fn C(Amp: int<A>, Second: int<s>) int<C> {
        return int<C>(int(Amp) * int(Second))
    }

    fn C(Amp: uint<A>, Second: uint<s>) uint<C> {
        return uint<C>(uint(Amp) * uint(Second))
    }    

    // --- Via Capacitance and Voltage: Q = C * V (Farad * Volt) ---

    fn C(Farad: decimal<F>, Volt: decimal<V>) decimal<C> {
        return decimal<C>(decimal(Farad) * decimal(Volt))
    }

    fn C(Farad: float<F>, Volt: float<V>) float<C> {
        return float<C>(float(Farad) * float(Volt))
    }

    fn C(Farad: int<F>, Volt: int<V>) int<C> {
        return int<C>(int(Farad) * int(Volt))
    }

    fn C(Farad: uint<F>, Volt: uint<V>) uint<C> {
        return uint<C>(uint(Farad) * uint(Volt))
    }

    // --- Via Energy and Voltage: Q = J / V (Joule / Volt) ---

    fn C(Joule: decimal<J>, Volt: decimal<V>) decimal<C> {
        return decimal<C>(decimal(Joule) / decimal(Volt))
    }

    fn C(Joule: float<J>, Volt: float<V>) float<C> {
        return float<C>(float(Joule) / float(Volt))
    }

    fn C(Joule: int<J>, Volt: int<V>) int<C> {
        return int<C>(int(Joule) / int(Volt))
    }

    fn C(Joule: uint<J>, Volt: uint<V>) uint<C> {
        return uint<C>(uint(Joule) / uint(Volt))
    }

    // --- Via Power, Time and Voltage: Q = (W * s) / V (Watt * Second / Volt) ---

    fn C(Watt: decimal<W>, Second: decimal<s>, Volt: decimal<V>) decimal<C> {
        return decimal<C>((decimal(Watt) * decimal(Second)) / decimal(Volt))
    }

    fn C(Watt: float<W>, Second: float<s>, Volt: float<V>) float<C> {
        return float<C>((float(Watt) * float(Second)) / float(Volt))
    }

    fn C(Watt: int<W>, Second: int<s>, Volt: int<V>) int<C> {
        return int<C>((int(Watt) * int(Second)) / int(Volt))
    }

    fn C(Watt: uint<W>, Second: uint<s>, Volt: uint<V>) uint<C> {
        return uint<C>((uint(Watt) * uint(Second)) / uint(Volt))
    }
}

/** Volt */
unit V decimal physical
impl V {

    dimension: [mass^1, length^2, time^-3, electric_current^-1]
    scale: 1
    system: SI

    fn V(Ohm: decimal<ohm>, Amp: decimal<A>) decimal<V> {
        return decimal<V>(decimal(Ohm) * decimal(Amp))
    }

    fn V(Ohm: float<ohm>, Amp: float<A>) float<V> {
        return float<V>(float(Ohm) * float(Amp))
    }

    fn V(Ohm: int<ohm>, Amp: int<A>) int<V> {
        return int<V>(int(Ohm) * int(Amp))
    }

    fn V(Ohm: uint<ohm>, Amp: uint<A>) uint<V> {
        return uint<V>(uint(Ohm) * uint(Amp))
    }

    /** Calculate Volt via Watt and Ampere (U = P / I) */
    fn V(Watt: decimal<W>, Amp: decimal<A>) decimal<V> {
        return decimal<V>(decimal(Watt) / decimal(Amp))
    }

    fn V(Watt: float<W>, Amp: float<A>) float<V> {
        return float<V>(float(Watt) / float(Amp))
    } 
}

/** Ohm */
unit ohm decimal physical
impl ohm {
    dimension: [mass^1, length^2, time^-3, electric_current^-2]
    scale: 1
    system: SI

    fn ohm(Volt: decimal<V>, Amp: decimal<A>) decimal<ohm> {
        return decimal<ohm>(decimal(Volt) / decimal(Amp))
    }

    fn ohm(Volt: float<V>, Amp: float<A>) float<ohm> {
        return float<ohm>(float(Volt) / float(Amp))
    }

    /** Calculate Ohm via Watt and Ampere (R = P / I^2) */
    fn ohm(Watt: decimal<W>, Amp: decimal<A>) decimal<ohm> {
        return decimal<ohm>(decimal(Watt) / (decimal(Amp) * decimal(Amp)))
    }

    fn ohm(Watt: float<W>, Amp: float<A>) float<ohm> {
        return float<ohm>(float(Watt) / (float(Amp) * float(Amp)))
    }

    /** Calculate Ohm via Volt and Watt (R = U^2 / P) */
    fn ohm(Volt: decimal<V>, Watt: decimal<W>) decimal<ohm> {
        return decimal<ohm>((decimal(Volt) * decimal(Volt)) / decimal(Watt))
    }

    fn ohm(Volt: float<V>, Watt: float<W>) float<ohm> {
        return float<ohm>((float(Volt) * float(Volt)) / float(Watt))
    }

    /** Calculate Ohm via Time and Capacitance (R = t / C) */
    fn ohm(Second: decimal<s>, Farad: decimal<F>) decimal<ohm> {
        return decimal<ohm>(decimal(Second) / decimal(Farad))
    }

    fn ohm(Second: float<s>, Farad: float<F>) float<ohm> {
        return float<ohm>(float(Second) / float(Farad))
    }

    /** Calculate Ohm via Inductance and Time (R = L / t) */
    fn ohm(Henry: decimal<H>, Second: decimal<s>) decimal<ohm> {
        return decimal<ohm>(decimal(Henry) / decimal(Second))
    }

    fn ohm(Henry: float<H>, Second: float<s>) float<ohm> {
        return float<ohm>(float(Henry) / float(Second))
    }
}

/** Siemens */
unit S decimal physical
impl S {
    dimension: [mass^-1, length^-2, time^3, electric_current^2]
    scale: 1
    system: SI

    fn S(Ohm: decimal<ohm>) decimal<S> {
        return decimal<S>(decimal(1) / decimal(Ohm))
    }

    fn S(Ohm: float<ohm>) float<S> {
        return float<S>(1.0f / float(Ohm))
    }

    fn S(Ohm: int<ohm>) int<S> {
        return int<S>(int(1) / int(Ohm))
    }

    fn S(Ohm: uint<ohm>) uint<S> {
        return uint<S>(uint(1) / uint(Ohm))
    }
}

/** Farad */
unit F decimal physical
impl F {
    dimension: [mass^-1, length^-2, time^4, electric_current^2]
    scale: 1
    system: SI

    fn F(Coulomb: decimal<C>, Volt: decimal<V>) decimal<F> {
        return decimal<F>(decimal(Coulomb) / decimal(Volt))
    }

    fn F(Coulomb: float<C>, Volt: float<V>) float<F> {
        return float<F>(float(Coulomb) / float(Volt))
    }

    fn F(Coulomb: int<C>, Volt: int<V>) int<F> {
        return int<F>(int(Coulomb) / int(Volt))
    }

    fn F(Coulomb: uint<C>, Volt: uint<V>) uint<F> {
        return uint<F>(uint(Coulomb) / uint(Volt))
    }
}

/** Weber */
unit Wb decimal physical
impl Wb {
    dimension: [mass^1, length^2, time^-2, electric_current^-1]
    scale: 1
    system: SI

    fn Wb(Volt: decimal<V>, Second: decimal<s>) decimal<Wb> {
        return decimal<Wb>(decimal(Volt) * decimal(Second))
    }

    fn Wb(Volt: float<V>, Second: float<s>) float<Wb> {
        return float<Wb>(float(Volt) * float(Second))
    }

    fn Wb(Volt: int<V>, Second: int<s>) int<Wb> {
        return int<Wb>(int(Volt) * int(Second))
    }

    fn Wb(Volt: uint<V>, Second: uint<s>) uint<Wb> {
        return uint<Wb>(uint(Volt) * uint(Second))
    }
}

/** Tesla */
unit T decimal physical
impl T {
    dimension: [mass^1, time^-2, electric_current^-1]
    scale: 1
    system: SI

}

/** Henry */
unit H decimal physical
impl H {
    dimension: [mass^1, length^2, time^-2, electric_current^-2]
    scale: 1
    system: SI

    fn H(Weber: decimal<Wb>, Amp: decimal<A>) decimal<H> {
        return decimal<H>(decimal(Weber) / decimal(Amp))
    }

    fn H(Weber: float<Wb>, Amp: float<A>) float<H> {
        return float<H>(float(Weber) / float(Amp))
    }

    fn H(Weber: int<Wb>, Amp: int<A>) int<H> {
        return int<H>(int(Weber) / int(Amp))
    }

    fn H(Weber: uint<Wb>, Amp: uint<A>) uint<H> {
        return uint<H>(uint(Weber) / uint(Amp))
    }
}

/** Radians per second (Angular frequency) */
unit rad_s decimal physical
impl rad_s {
    dimension: [time^-1]
    scale: 1
    system: SI

    /** Calculate angular frequency from Hertz (omega = 2 * pi * f) */
    fn rad_s(Hertz: decimal<Hz>) decimal<rad_s> {
        return decimal<rad_s>(3.141592653589793d * 2d * decimal(Hertz))
    }

    fn rad_s(Hertz: float<Hz>) float<rad_s> {
        return float<rad_s>(3.14159265f * 2f * float(Hertz))
    }
}

