module main
// defer_invalid.sec
// Every marked declaration or expression must produce a semantic error.

// Parser-only invalid form intentionally belongs in a separate parser test:
//
//     defer Cleanup()
//
// Keeping it out of this file allows all semantic errors below to be found.

enum CleanupError {
    failed,
}

type Resource struct {
    id: int
}

fn Record(value: int) void {
}

fn CloseResource(resource: Resource) Result[void, CleanupError] {
    if resource.id < 0 {
        return Err(CleanupError.failed)
    }

    return Ok()
}

fn ReadResource(resource: Resource) Result[int, CleanupError] {
    if resource.id < 0 {
        return Err(CleanupError.failed)
    }

    return Ok(resource.id)
}

// Defer tests

// Ok: Warning: superfluous defer return 
fn DeferWithReturn() void {
    defer {
        return
    }
}

// Ok: sema error: return is not allowed inside defer
fn DeferWithReturnValue() int {
    defer {
        return 10
    }

    return 20
}

// Ok: Warning: defer inside loop registers once per execution and runs at function exit
// sema error: break is not allowed inside defer 
fn DeferWithBreak() void {
    for {
        defer {
            break
        }

        break
    }
}

// Ok: Warning: defer inside loop registers once per execution and runs at function exit
// sema error: continue is not allowed inside defer
fn DeferWithContinue() void {
    for {
        defer {
            continue
        }

        break
    }
}

// Ok: sema error: fallthrough is not allowed inside defer
fn DeferWithFallthrough(value: int) void {
    switch value {
    case 1:
        defer {
            fallthrough
        }
    case 2:
    }
}

// Ok: sema error: defer is not allowed inside defer
fn NestedDefer() void {
    defer {
        defer {
            Record(1)
        }
    }
}

// Ok: sema error: try cannot propagate from inside defer
fn TryPropagationInsideDefer(resource: Resource) Result[void, CleanupError] {
    defer {
        let value := try ReadResource(resource)
        Record(value)
    }

    return Ok()
}

// Ok: sema error: try cannot propagate from inside defer
fn BareTryInsideDefer(resource: Resource) Result[void, CleanupError] {
    defer {
        try CloseResource(resource)
    }

    return Ok()
}

// Ok: sema error: unhandled Result inside defer; handle it or discard it explicitly
fn UnhandledResultInsideDefer(resource: Resource) void {
    defer {
        CloseResource(resource)
    }
}

// Ok: sema error: non-exhaustive match for Result[void, CleanupError]: missing Err
fn PartiallyHandledResultInsideDefer(resource: Resource) void {
    defer {
        match CloseResource(resource) {
            Ok(_) => {
            }
        }
    }
}

// Ok: sema error: undefined variable value
fn ReferenceDeclaredAfterDefer() void {
    defer {
        Record(value)
    }

    let value := 10
}

// Ok: sema error: variable value is unassigned
fn DeferredReadBeforeDefiniteAssignment() void {
    let mut value: int

    defer {
        Record(value)
    }
}

// Ok: sema error: variable value is unassigned
fn DeferredMaybeInitialized(condition: bool) void {
    let mut value: int

    defer {
        Record(value)
    }

    if condition {
        value = 10
    }
}

// Ok: sema error: return is not allowed inside defer
fn ErrorFromDeferredHandler(resource: Resource) Result[void, CleanupError] {
    defer {
        match CloseResource(resource) {
            Ok(_) => {
            }

            Err(error) => {
                return Err(error)
            }
        }
    }

    return Ok()
}
