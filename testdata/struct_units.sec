module main

type A struct {
    x: int,
}

type B struct {
    y: int,          // Missing ':'
}

type C struct {
    z: int,
}

let a := 10

type Kilowatt int<kwh>

type Vehicle struct {
    fuel_type: Vehicle.FuelTypes,
    engine: Vehicle.Engine
}

impl Vehicle {

    enum FuelTypes {
        Petrol,
        Diecel,
        Gas,
        Electric,
    }

    type Engine struct {
        power: Kilowatt,
    }

}

let mut ft: Vehicle.FuelTypes := Vehicle.FuelTypes.Petrol